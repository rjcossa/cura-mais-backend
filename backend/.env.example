# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# For docker-compose, DATABASE_URL is overridden automatically to point at
# the `db` service — the value below is what's used for a bare-metal
# (non-Docker) local run instead.

# --- General ---------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=false

# --- Database ----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://health_platform:health_platform_dev@localhost:5432/health_platform

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for browser-based clients.
CORS_ORIGINS=http://localhost:3000

# --- JWT (RS256) ---------------------------------------------------------------
# Generate with: python scripts/generate_jwt_keys.py
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- Refresh tokens ------------------------------------------------------------
REFRESH_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_REMEMBER_EXPIRE_DAYS=90

# --- Secrets -------------------------------------------------------------------
# REQUIRED — generate real values before running anywhere but a throwaway
# local sandbox. `python scripts/generate_jwt_keys.py` prints ready-to-use
# values for both of these.
TOKEN_HASH_PEPPER=CHANGE_ME_dev_only_token_hash_pepper
MFA_ENCRYPTION_KEY=CHANGE_ME_dev_only_fernet_key_44_chars_______=

# --- Password policy -----------------------------------------------------------
PASSWORD_MIN_LENGTH=10
PASSWORD_MAX_LENGTH=128
PASSWORD_HISTORY_SIZE=5

# --- Account lockout -------------------------------------------------------------
FAILED_LOGIN_ATTEMPTS_BEFORE_LOCK=5
ACCOUNT_LOCK_DURATION_MINUTES=15
REQUIRE_EMAIL_VERIFICATION_TO_LOGIN=false

# --- Verification / OTP -----------------------------------------------------------
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
MOBILE_OTP_LENGTH=6
MOBILE_OTP_EXPIRE_MINUTES=5
MOBILE_OTP_MAX_ATTEMPTS=5
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
MFA_CHALLENGE_EXPIRE_MINUTES=5
MFA_ENROLMENT_EXPIRE_MINUTES=15
RECOVERY_CODES_COUNT=10

# --- Social login (optional — leave unset to disable a given provider) -------------
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Notifications -----------------------------------------------------------------
# SMS is mock-only for now (no real provider wired up yet).
SMS_PROVIDER=mock

# Email: "mock" (console/in-memory, zero config) or "smtp" (real delivery).
EMAIL_PROVIDER=mock
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM_ADDRESS=no-reply@health-platform.example

FRONTEND_BASE_URL=http://localhost:3000
